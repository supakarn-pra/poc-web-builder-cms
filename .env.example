# คัดลอกเป็น .env แล้วแก้ค่า

# SQLite (POC) — path ภายใน container/เครื่อง
# Production ที่ Vercel: เปลี่ยนเป็น Postgres แล้วดู DEPLOY.md
DATABASE_URL="file:./dev.db"

# ความลับสำหรับเซ็น session JWT — ต้องเปลี่ยนใน production!
# สร้างด้วย: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
